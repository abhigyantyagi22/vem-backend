# Backend environment example for VEM
# Copy this file to `backend/.env` or set equivalent environment variables.

# Database (MySQL)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/vem_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=vem_user
SPRING_DATASOURCE_PASSWORD=vem_password

# JWT
# A secure base64-encoded 32-byte secret (example generated for local use).
JWT_SECRET=REPLACE_WITH_SECURE_BASE64_32_BYTE_KEY

# CORS allowed frontend origins (comma-separated)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://vem-ochre.vercel.app

# Server
SERVER_PORT=8080
